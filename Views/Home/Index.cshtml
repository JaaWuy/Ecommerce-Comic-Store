@{
    ViewBag.Title = "Trang chủ";
    var sliderProducts = ViewBag.SliderProducts as List<DoAnWeb.Models.Truyen>;
}

<style>
    /* Hero Carousel - Large Single Product */
    .hero-carousel {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
        margin-bottom: 40px;
    }

    .carousel-slide {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 40px 40px 70px 40px; /* Increased bottom padding */
        min-height: 380px;
    }



    .carousel-content-wrapper {
        display: flex;
        align-items: center;
        gap: 40px;
        max-width: 100%;
    }

    .carousel-image-box {
        flex-shrink: 0;
        width: 260px;
    }

    .carousel-image-box img {
        width: 100%;
        height: 300px;
        object-fit: cover;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        transition: transform 0.4s ease;
    }

    .carousel-image-box:hover img {
        transform: scale(1.05);
    }

    .carousel-product-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 15px;
        backdrop-filter: blur(10px);
    }

    .carousel-info-box {
        flex: 1;
        color: white;
    }

    .carousel-info-box h2 {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 15px;
        line-height: 1.3;
    }

    .carousel-info-box .price {
        font-size: 36px;
        font-weight: 800;
        color: #ffd700;
        margin-bottom: 15px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
    }

    .carousel-info-box .description {
        font-size: 16px;
        opacity: 0.9;
        margin-bottom: 25px;
        line-height: 1.6;
    }

    .carousel-info-box .description i {
        color: #ffd700;
        margin-right: 8px;
    }

    .btn-carousel-view {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 36px;
        background: white;
        color: #667eea;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 16px;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .btn-carousel-view:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
        color: #764ba2;
    }

    .btn-carousel-cart {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 36px;
        background: rgba(255, 255, 255, 0.15);
        color: white;
        border: 2px solid rgba(255, 255, 255, 0.5);
        border-radius: 12px;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-left: 15px;
        backdrop-filter: blur(10px);
    }

    .btn-carousel-cart:hover {
        background: white;
        color: #667eea;
        border-color: white;
    }

    .carousel-control-prev,
    .carousel-control-next {
        width: 50px;
        height: 50px;
        background: white;
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0.9;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }

    .carousel-control-prev { left: 15px; }
    .carousel-control-next { right: 15px; }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(1) grayscale(100);
    }

    .carousel-indicators {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        right: auto;
        margin: 0;
        padding: 0;
        background: transparent;
        display: flex;
        gap: 8px;
        z-index: 10;
    }

    .carousel-indicators button {
        width: 25px; /* Rounded rectangle width */
        height: 4px; /* Rounded rectangle height */
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.4);
        border: none;
        margin: 0;
        opacity: 1;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .carousel-indicators button.active {
        background: white;
        width: 35px; /* Slightly longer when active */
        height: 4px;
        transform: none;
        box-shadow: 0 0 8px rgba(255, 255, 255, 0.4);
    }

    /* Section Headers */
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
    }

    .section-title {
        font-size: 22px;
        font-weight: 700;
        color: #1a202c;
        margin: 0;
    }

    .section-title i {
        color: #667eea;
        margin-right: 10px;
    }

    .btn-view-all {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-view-all:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    /* Product Cards */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .product-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
    }

    .product-image-wrapper {
        position: relative;
        overflow: hidden;
    }

    .product-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.08);
    }

    .product-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .product-content {
        padding: 15px;
    }

    .product-title {
        font-size: 14px;
        font-weight: 600;
        color: #1a202c;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-title a {
        color: inherit;
        text-decoration: none;
    }

    .product-title a:hover {
        color: #667eea;
    }

    .product-price {
        font-size: 18px;
        font-weight: 700;
        color: #ef4444;
        margin-bottom: 12px;
    }

    .btn-add-cart {
        width: 100%;
        padding: 10px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-add-cart:hover {
        box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
    }

    .btn-login-to-buy {
        width: 100%;
        padding: 10px;
        background: white;
        color: #667eea;
        border: 2px solid #667eea;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        text-decoration: none;
        display: block;
        text-align: center;
        transition: all 0.3s ease;
    }

    .btn-login-to-buy:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
    }

    /* Features */
    .features-section {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 30px;
    }

    .feature-card {
        background: white;
        border-radius: 16px;
        padding: 25px 20px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 24px;
        color: white;
    }

    .feature-icon.shipping { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .feature-icon.payment { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
    .feature-icon.returns { background: linear-gradient(135deg, #F2994A 0%, #F2C94C 100%); }
    .feature-icon.support { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }

    .feature-title {
        font-size: 16px;
        font-weight: 700;
        color: #1a202c;
        margin-bottom: 8px;
    }

    .feature-desc {
        color: #64748b;
        font-size: 13px;
        margin: 0;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .carousel-content-wrapper { flex-direction: column; text-align: center; }
        .carousel-image-box { width: 200px; }
        .product-grid { grid-template-columns: repeat(2, 1fr); }
        .features-section { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 576px) {
        .product-grid { grid-template-columns: 1fr; }
        .features-section { grid-template-columns: 1fr; }
        .carousel-info-box h2 { font-size: 24px; }
        .carousel-info-box .price { font-size: 28px; }
    }
</style>

<!-- Hero Carousel - Large Single Product -->
<div id="productCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel">
    <div class="carousel-indicators">
        @for (int i = 0; i < sliderProducts.Count; i++)
        {
            <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
        }
    </div>
    <div class="carousel-inner">
        @{ int index = 0; }
        @foreach (var item in sliderProducts)
        {
            <div class="carousel-item @(index == 0 ? "active" : "")" data-bs-interval="4000">
                <div class="carousel-slide">
                    <div class="carousel-content-wrapper">
                        <div class="carousel-image-box">
                            <a href="@Url.Action("Detail", "Truyen", new { id = item.MaTruyen })">
                                <img src="@item.imgUrl" alt="@item.TenTruyen">
                            </a>
                        </div>
                        <div class="carousel-info-box">
                            @if (item.TheLoai != null)
                            {
                                <span class="carousel-product-badge">
                                    <i class="fas fa-tag"></i> @item.TheLoai.TenTL
                                </span>
                            }
                            <h2>@item.TenTruyen</h2>
                            <div class="price">@item.GiaBan.ToString("N0")đ</div>
                            <p class="description">
                                <i class="fas fa-fire"></i> Đang hot! Khám phá ngay câu chuyện hấp dẫn này cùng hàng ngàn độc giả!
                            </p>
                            <div>
                                <a href="@Url.Action("Detail", "Truyen", new { id = item.MaTruyen })" class="btn-carousel-view">
                                    <i class="fas fa-eye"></i> Xem chi tiết
                                </a>
                                @if (Request.IsAuthenticated)
                                {
                                    <button class="btn-carousel-cart" onclick="addToCart('@item.MaTruyen')">
                                        <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            index++;
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- Featured Products -->
<section>
    <div class="section-header">
        <h3 class="section-title">
            <i class="fas fa-star"></i> Sản phẩm nổi bật
        </h3>
        <a href="@Url.Action("Index", "Truyen")" class="btn-view-all">
            Xem tất cả <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div class="product-grid">
        @foreach (var item in ViewBag.FeaturedProducts as List<DoAnWeb.Models.Truyen>)
        {
            <div class="product-card">
                <div class="product-image-wrapper">
                    <a href="@Url.Action("Detail", "Truyen", new { id = item.MaTruyen })">
                        <img src="@item.imgUrl" alt="@item.TenTruyen" class="product-image">
                    </a>
                    <span class="product-badge">@item.TheLoai.TenTL</span>
                </div>
                <div class="product-content">
                    <h6 class="product-title">
                        <a href="@Url.Action("Detail", "Truyen", new { id = item.MaTruyen })">@item.TenTruyen</a>
                    </h6>
                    <div class="product-price">@item.GiaBan.ToString("N0")đ</div>
                    @if (Request.IsAuthenticated)
                    {
                        @Html.AntiForgeryToken()
                        <button class="btn-add-cart" onclick="addToCart('@item.MaTruyen')">
                            <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                        </button>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn-login-to-buy">
                            <i class="fas fa-sign-in-alt"></i> Đăng nhập để mua
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</section>

