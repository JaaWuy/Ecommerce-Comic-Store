@model DoAnWeb.Models.Order
@{
    ViewBag.Title = "Xác nhận đơn hàng";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white text-center">
                <h3 class="mb-0">
                    <i class="fas fa-check-circle fa-3x mb-3"></i>
                    <br>Đặt hàng thành công!
                </h3>
            </div>
            <div class="card-body">
                <div class="alert alert-success">
                    <i class="fas fa-info-circle"></i>
                    Cảm ơn bạn đã đặt hàng! Đơn hàng của bạn đã được ghi nhận và đang được xử lý.
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h5><i class="fas fa-file-invoice"></i> Thông tin đơn hàng</h5>
                        <table class="table table-sm">
                            <tr>
                                <th>Mã đơn hàng:</th>
                                <td><strong class="text-danger">#@Model.OrderId</strong></td>
                            </tr>
                            <tr>
                                <th>Ngày đặt:</th>
                                <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <th>Trạng thái:</th>
                                <td><span class="badge bg-warning">@Model.Status</span></td>
                            </tr>
                            <tr>
                                <th>Thanh toán:</th>
                                <td>
                                    @if (Model.PaymentMethod == "COD")
                                    {
                                        <i class="fas fa-money-bill-wave text-success"></i> <span>Thanh toán khi nhận hàng</span>
                                    }
                                    else if (Model.PaymentMethod == "Chuyển khoản")
                                    {
                                        <i class="fas fa-university text-primary"></i> <span>Chuyển khoản ngân hàng</span>
                                    }
                                    else if (Model.PaymentMethod == "Ví điện tử")
                                    {
                                        <i class="fas fa-mobile-alt text-info"></i> <span>Ví điện tử</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h5><i class="fas fa-shipping-fast"></i> Thông tin giao hàng</h5>
                        <table class="table table-sm">
                            <tr>
                                <th>Người nhận:</th>
                                <td>@Model.ReceiverName</td>
                            </tr>
                            <tr>
                                <th>Số điện thoại:</th>
                                <td>@Model.ReceiverPhone</td>
                            </tr>
                            <tr>
                                <th>Địa chỉ:</th>
                                <td>@Model.ShippingAddress</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <h5><i class="fas fa-shopping-bag"></i> Chi tiết đơn hàng</h5>
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>STT</th>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int stt = 1; }
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td>@stt</td>
                                    <td>@detail.Truyen.TenTruyen</td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end">@detail.Price.ToString("N0")đ</td>
                                    <td class="text-end text-danger fw-bold">@detail.SubTotal.ToString("N0")đ</td>
                                </tr>
                                stt++;
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="4" class="text-end"><strong>Tổng cộng:</strong></td>
                                <td class="text-end text-danger fw-bold fs-5">@Model.TotalAmount.ToString("N0")đ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="alert alert-secondary">
                        <strong><i class="fas fa-sticky-note"></i> Ghi chú:</strong> @Model.Note
                    </div>
                }

                <div class="text-center mt-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg me-2">
                        <i class="fas fa-home"></i> Về trang chủ
                    </a>
                    <a href="@Url.Action("Index", "Truyen")" class="btn btn-danger btn-lg">
                        <i class="fas fa-shopping-bag"></i> Tiếp tục mua sắm
                    </a>
                </div>

                <div class="alert alert-info mt-4">
                    <i class="fas fa-info-circle"></i>
                    <strong>Thông tin:</strong> Chúng tôi sẽ liên hệ với bạn trong vòng 24h để xác nhận đơn hàng. 
                    Vui lòng kiểm tra email hoặc số điện thoại để nhận thông tin cập nhật về đơn hàng.
                </div>
            </div>
        </div>
    </div>
</div>
