@model PagedList.IPagedList<DoAnWeb.Models.Truyen>
@using PagedList.Mvc
@{
    ViewBag.Title = "Quản Lý Sản Phẩm";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-box"></i> Danh Sách Sản Phẩm</span>
        <a href="@Url.Action("Create")" class="btn btn-admin btn-sm">
            <i class="fas fa-plus"></i> Thêm Sản Phẩm
        </a>
    </div>
    <div class="card-body">
        <!-- Tìm kiếm và lọc -->
        <form method="get" class="mb-3">
            <div class="row">
                <div class="col-md-5">
                    <input type="text" name="search" class="form-control" placeholder="Tìm kiếm sản phẩm..." value="@ViewBag.Search">
                </div>
                <div class="col-md-4">
                    <select name="category" class="form-select">
                        <option value="">Tất cả thể loại</option>
                        @foreach (var tl in ViewBag.TheLoai)
                        {
                            <option value="@tl.MaTL" @(ViewBag.Category == tl.MaTL ? "selected" : "")>@tl.TenTL</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-admin w-100" type="submit">
                        <i class="fas fa-search"></i> Tìm Kiếm
                    </button>
                </div>
            </div>
        </form>

        <!-- Bảng danh sách -->
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Mã SP</th>
                        <th>Tên Sản Phẩm</th>
                        <th>Thể Loại</th>
                        <th>Giá Bán</th>
                        <th>Số Lượng</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>@product.MaTruyen</td>
                            <td>@product.TenTruyen</td>
                            <td>@product.TheLoai.TenTL</td>
                            <td>@product.GiaBan.ToString("N0")đ</td>
                            <td>
                                @if (product.SoLuongTon < 10)
                                {
                                    <span class="badge bg-danger">@product.SoLuongTon</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@product.SoLuongTon</span>
                                }
                            </td>
                            <td class="text-nowrap">
                                <a href="@Url.Action("Edit", new { id = product.MaTruyen })" class="btn btn-sm btn-warning me-1" title="Chỉnh sửa sản phẩm">
                                    <i class="fas fa-edit me-1"></i>Sửa
                                </a>
                                <a href="@Url.Action("Delete", new { id = product.MaTruyen })" class="btn btn-sm btn-danger" title="Xóa sản phẩm" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                    <i class="fas fa-trash me-1"></i>Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Phân trang -->
        @if (Model.PageCount > 1)
        {
            <div class="d-flex justify-content-center">
                @Html.PagedListPager(Model, page => Url.Action("Index", new { search = ViewBag.Search, category = ViewBag.Category, page }), new PagedListRenderOptions
                {
                    UlElementClasses = new[] { "pagination" },
                    LiElementClasses = new[] { "page-item" }
                })
            </div>
        }
    </div>
</div>
