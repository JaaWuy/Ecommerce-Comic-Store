@model dynamic
@{
    ViewBag.Title = "Dashboard";
}

<div class="row">
    <!-- Thống kê tổng quan -->
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1">Tổng Người Dùng</p>
                    <h3>@ViewBag.TotalUsers</h3>
                </div>
                <i class="fas fa-users fa-3x" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card success">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1">Tổng Sản Phẩm</p>
                    <h3>@ViewBag.TotalProducts</h3>
                </div>
                <i class="fas fa-box fa-3x" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card warning">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1">Tổng Đơn Hàng</p>
                    <h3>@ViewBag.TotalOrders</h3>
                </div>
                <i class="fas fa-shopping-cart fa-3x" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card info">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1">Tổng Doanh Thu</p>
                    <h3>@ViewBag.TotalRevenue.ToString("N0")đ</h3>
                </div>
                <i class="fas fa-dollar-sign fa-3x" style="opacity: 0.3;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Đơn hàng gần đây -->
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-shopping-bag"></i> Đơn Hàng Gần Đây
            </div>
            <div class="card-body">
                @if (ViewBag.RecentOrders != null && ViewBag.RecentOrders.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Mã ĐH</th>
                                    <th>Khách Hàng</th>
                                    <th>Ngày Đặt</th>
                                    <th>Tổng Tiền</th>
                                    <th>Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in ViewBag.RecentOrders)
                                {
                                    <tr>
                                        <td><a href="@Url.Action("Details", "Orders", new { id = order.OrderId })">#@order.OrderId</a></td>
                                        <td>@(order.User != null ? order.User.FullName : "Khách vãng lai")</td>
                                        <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                        <td>@order.TotalAmount.ToString("N0")đ</td>
                                        <td>
                                            @if (order.Status == "Pending")
                                            {
                                                <span class="badge bg-warning">Chờ xử lý</span>
                                            }
                                            else if (order.Status == "Processing")
                                            {
                                                <span class="badge bg-info">Đang xử lý</span>
                                            }
                                            else if (order.Status == "Shipped")
                                            {
                                                <span class="badge bg-primary">Đang giao</span>
                                            }
                                            else if (order.Status == "Delivered")
                                            {
                                                <span class="badge bg-success">Đã giao</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Đã hủy</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">Chưa có đơn hàng nào</p>
                }
                <div class="text-end">
                    <a href="@Url.Action("Index", "Orders")" class="btn btn-admin btn-sm">
                        Xem Tất Cả <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Sản phẩm sắp hết hàng -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-exclamation-triangle"></i> Sản Phẩm Sắp Hết Hàng
            </div>
            <div class="card-body">
                @if (ViewBag.LowStockProducts != null && ViewBag.LowStockProducts.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Sản Phẩm</th>
                                    <th>Số Lượng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in ViewBag.LowStockProducts)
                                {
                                    <tr>
                                        <td>
                                            <a href="@Url.Action("Edit", "Products", new { id = product.MaTruyen })">
                                                @product.TenTruyen
                                            </a>
                                        </td>
                                        <td>
                                            <span class="badge bg-danger">@product.SoLuongTon</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">Tất cả sản phẩm đều còn đủ hàng</p>
                }
                <div class="text-end">
                    <a href="@Url.Action("Index", "Products")" class="btn btn-admin btn-sm">
                        Xem Tất Cả <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
